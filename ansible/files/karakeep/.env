# Karakeep configuration — see https://docs.karakeep.app/configuration

# === REQUIRED ===
KARAKEEP_PORT=5272
DATA_DIR=/data
MEILI_ADDR=http://meilisearch:7700
MEILI_MASTER_KEY=CHANGE_ME_MEILI_MASTER_KEY
NEXTAUTH_URL=https://keep.x3c.ca
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
DISABLE_SIGNUPS=true

# === OPTIONAL: AI Auto-Tagging ===
# Uncomment and set these to enable AI tagging:
#   Google AI Studio (Gemini) — free tier, OpenAI-compatible:
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# OPENAI_API_KEY=your-google-ai-studio-key
# INFERENCE_TEXT_MODEL=gemini-3.1-flash-lite
# INFERENCE_IMAGE_MODEL=gemini-3.1-flash-lite
#
#   Note: Gemma 4 models (gemma-4-31b-it) do NOT work via the OpenAI-compatible
#   endpoint. Use Gemini models (gemini-3.1-flash-lite, gemini-2.5-flash, etc.) instead.

# === OPTIONAL: Image tag ===
# KARAKEEP_VERSION=release
